{
    "$schema": "https://calm.finos.org/release/1.2/meta/calm.json",
    "unique-id": "ecommerce-order-processing-platform",
    "name": "E-Commerce Order Processing Platform",
    "description": "End-to-end order processing platform for e-commerce, covering order placement, inventory management, and payment processing",
    "metadata": {
        "owner": "platform-team@example.com",
        "version": "1.0.0",
        "created": "2026-04-12",
        "description": "E-commerce order processing platform",
        "tags": ["ecommerce", "microservices", "orders"]
    },
    "controls": {
        "security": {
            "description": "Data encryption and secure communication requirements",
            "requirements": [
                {
                    "requirement-url": "https://internal-policy.example.com/security/encryption-at-rest",
                    "config": {
                        "algorithm": "AES-256",
                        "scope": "all-data-stores"
                    }
                },
                {
                    "requirement-url": "https://internal-policy.example.com/security/tls-1-3-minimum",
                    "config-url": "https://configs.example.com/security/tls-config.yaml"
                }
            ]
        },
        "performance": {
            "description": "System-wide performance and scalability requirements",
            "requirements": [
                {
                    "requirement-url": "https://internal-policy.example.com/performance/response-time-sla",
                    "config": {
                        "p99-latency-ms": 200,
                        "p95-latency-ms": 100
                    }
                },
                {
                    "requirement-url": "https://internal-policy.example.com/performance/availability-target",
                    "config-url": "https://configs.example.com/infra/ha-config.yaml"
                }
            ]
        }
    },
    "nodes": [
        {
            "unique-id": "customer",
            "node-type": "actor",
            "name": "Customer",
            "description": "End user who browses the store, places orders, and tracks order status through the e-commerce platform"
        },
        {
            "unique-id": "admin",
            "node-type": "actor",
            "name": "Admin",
            "description": "Internal platform administrator who manages inventory, reviews orders, and configures platform settings"
        },
        {
            "unique-id": "api-gateway",
            "node-type": "service",
            "name": "API Gateway",
            "description": "Single entry point for all client requests; handles routing, authentication, rate limiting, and load balancing across downstream services",
            "interfaces": [
                {
                    "unique-id": "api-gateway-https",
                    "protocol": "HTTPS",
                    "host": "api.ecommerce.example.com",
                    "port": 443,
                    "path": "/api/v1"
                }
            ],
            "metadata": {
                "owner": "platform-team@example.com",
                "repository": "https://github.com/example-org/api-gateway",
                "deployment-type": "container",
                "sla-tier": "tier-1"
            },
            "controls": {
                "performance": {
                    "description": "API Gateway rate limiting and caching requirements",
                    "requirements": [
                        {
                            "requirement-url": "https://internal-policy.example.com/performance/rate-limiting",
                            "config-url": "https://configs.example.com/gateway/rate-limits.yaml"
                        },
                        {
                            "requirement-url": "https://internal-policy.example.com/performance/caching-policy",
                            "config": {
                                "default-ttl-seconds": 300,
                                "cache-control": "private"
                            }
                        }
                    ]
                }
            }
        },
        {
            "unique-id": "order-service",
            "node-type": "service",
            "name": "Order Service",
            "description": "Manages the full order lifecycle: creation, status tracking, fulfilment coordination with inventory, and payment initiation",
            "interfaces": [
                {
                    "unique-id": "order-service-http",
                    "protocol": "HTTP",
                    "host": "order-service.internal",
                    "port": 8080,
                    "path": "/orders"
                }
            ],
            "metadata": {
                "owner": "platform-team@example.com",
                "repository": "https://github.com/example-org/order-service",
                "deployment-type": "container",
                "sla-tier": "tier-1"
            }
        },
        {
            "unique-id": "inventory-service",
            "node-type": "service",
            "name": "Inventory Service",
            "description": "Tracks stock levels, reserves items during order processing, and triggers restocking alerts when thresholds are breached",
            "interfaces": [
                {
                    "unique-id": "inventory-service-http",
                    "protocol": "HTTP",
                    "host": "inventory-service.internal",
                    "port": 8081,
                    "path": "/inventory"
                }
            ],
            "metadata": {
                "owner": "platform-team@example.com",
                "repository": "https://github.com/example-org/inventory-service",
                "deployment-type": "container",
                "sla-tier": "tier-2"
            }
        },
        {
            "unique-id": "payment-service",
            "node-type": "service",
            "name": "Payment Service",
            "description": "Processes payment authorisations, captures, and refunds via downstream payment gateways; enforces PCI-DSS compliance",
            "interfaces": [
                {
                    "unique-id": "payment-service-https",
                    "protocol": "HTTPS",
                    "host": "payment-service.internal",
                    "port": 8443,
                    "path": "/payments"
                }
            ],
            "metadata": {
                "owner": "platform-team@example.com",
                "repository": "https://github.com/example-org/payment-service",
                "deployment-type": "container",
                "sla-tier": "tier-1"
            },
            "controls": {
                "compliance": {
                    "description": "PCI-DSS compliance for payment processing",
                    "requirements": [
                        {
                            "requirement-url": "https://www.pcisecuritystandards.org/documents/PCI-DSS-v4.0",
                            "config-url": "https://configs.example.com/compliance/pci-dss-config.json"
                        }
                    ]
                }
            }
        },
        {
            "unique-id": "order-database",
            "node-type": "database",
            "name": "Order Database",
            "description": "Primary relational store for order records, order line items, and order status history",
            "interfaces": [
                {
                    "unique-id": "order-db-connection",
                    "protocol": "JDBC",
                    "host": "order-db.internal",
                    "port": 5432,
                    "database": "orders"
                }
            ],
            "metadata": {
                "owner": "platform-team@example.com",
                "repository": "https://github.com/example-org/order-service",
                "deployment-type": "managed",
                "engine": "PostgreSQL 15"
            }
        },
        {
            "unique-id": "inventory-database",
            "node-type": "database",
            "name": "Inventory Database",
            "description": "Persistent store for product catalogue, stock quantities, warehouse locations, and reservation records",
            "interfaces": [
                {
                    "unique-id": "inventory-db-connection",
                    "protocol": "JDBC",
                    "host": "inventory-db.internal",
                    "port": 5432,
                    "database": "inventory"
                }
            ],
            "metadata": {
                "owner": "platform-team@example.com",
                "repository": "https://github.com/example-org/inventory-service",
                "deployment-type": "managed",
                "engine": "PostgreSQL 15"
            }
        },
        {
            "unique-id": "ecommerce-platform",
            "node-type": "system",
            "name": "E-Commerce Platform",
            "description": "Top-level system boundary encompassing all services and data stores that together deliver the e-commerce order processing capability",
            "metadata": {
                "owner": "platform-team@example.com",
                "repository": "https://github.com/example-org/ecommerce-platform",
                "deployment-type": "cloud",
                "environment": "production"
            }
        }
    ],
    "relationships": [
        {
            "unique-id": "customer-uses-platform",
            "description": "Browses products, places orders, and tracks order status through",
            "relationship-type": {
                "interacts": {
                    "actor": "customer",
                    "nodes": ["api-gateway"]
                }
            }
        },
        {
            "unique-id": "admin-uses-platform",
            "description": "Manages inventory and reviews order data through",
            "relationship-type": {
                "interacts": {
                    "actor": "admin",
                    "nodes": ["api-gateway"]
                }
            }
        },
        {
            "unique-id": "api-gateway-to-order-service",
            "description": "Routes order-related requests to",
            "relationship-type": {
                "connects": {
                    "source": {
                        "node": "api-gateway",
                        "interfaces": ["api-gateway-https"]
                    },
                    "destination": {
                        "node": "order-service",
                        "interfaces": ["order-service-http"]
                    }
                }
            },
            "protocol": "HTTPS",
            "metadata": {
                "latency-sla": "< 200ms p99",
                "monitoring": true
            }
        },
        {
            "unique-id": "api-gateway-to-inventory-service",
            "description": "Routes inventory and product queries to",
            "relationship-type": {
                "connects": {
                    "source": {
                        "node": "api-gateway",
                        "interfaces": ["api-gateway-https"]
                    },
                    "destination": {
                        "node": "inventory-service",
                        "interfaces": ["inventory-service-http"]
                    }
                }
            },
            "protocol": "HTTPS",
            "metadata": {
                "latency-sla": "< 200ms p99",
                "monitoring": true
            }
        },
        {
            "unique-id": "order-service-to-payment-service",
            "description": "Initiates and confirms payment authorisation with",
            "relationship-type": {
                "connects": {
                    "source": {
                        "node": "order-service",
                        "interfaces": ["order-service-http"]
                    },
                    "destination": {
                        "node": "payment-service",
                        "interfaces": ["payment-service-https"]
                    }
                }
            },
            "protocol": "HTTPS",
            "metadata": {
                "latency-sla": "< 500ms p99",
                "monitoring": true,
                "circuit-breaker": true
            }
        },
        {
            "unique-id": "order-service-to-order-db",
            "description": "Reads and writes order records to",
            "relationship-type": {
                "connects": {
                    "source": {
                        "node": "order-service",
                        "interfaces": ["order-service-http"]
                    },
                    "destination": {
                        "node": "order-database",
                        "interfaces": ["order-db-connection"]
                    }
                }
            },
            "protocol": "JDBC",
            "metadata": {
                "latency-sla": "< 100ms p99",
                "monitoring": true,
                "circuit-breaker": true
            }
        },
        {
            "unique-id": "inventory-service-to-inventory-db",
            "description": "Reads and writes stock and product records to",
            "relationship-type": {
                "connects": {
                    "source": {
                        "node": "inventory-service",
                        "interfaces": ["inventory-service-http"]
                    },
                    "destination": {
                        "node": "inventory-database",
                        "interfaces": ["inventory-db-connection"]
                    }
                }
            },
            "protocol": "JDBC",
            "metadata": {
                "latency-sla": "< 100ms p99",
                "monitoring": true
            }
        },
        {
            "unique-id": "ecommerce-platform-composed-of-services",
            "description": "Composed of all services and data stores that deliver order processing",
            "relationship-type": {
                "composed-of": {
                    "container": "ecommerce-platform",
                    "nodes": [
                        "api-gateway",
                        "order-service",
                        "inventory-service",
                        "payment-service",
                        "order-database",
                        "inventory-database"
                    ]
                }
            }
        }
    ]
}
